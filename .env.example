# Copy this file to .env.local for local development or configure the same
# variables in Vercel. Never commit real secrets.

# Canonical production URL. No trailing slash.
NEXT_PUBLIC_SITE_URL=https://example.ro

# Server-only HTTPS endpoint that receives validated contact requests.
# TODO(client): replace with the real CRM, automation, or email webhook.
CONTACT_WEBHOOK_URL=https://example.com/secure-contact-webhook

# Tracking IDs are public identifiers, but scripts load only after consent.
# GA4 format: G-XXXXXXXXXX
NEXT_PUBLIC_GA_ID=
# GTM format: GTM-XXXXXXX
NEXT_PUBLIC_GTM_ID=
# Microsoft Clarity project ID
NEXT_PUBLIC_CLARITY_PROJECT_ID=

# Public contact details.
# TODO(client): complete every value with verified business information.
NEXT_PUBLIC_CONTACT_EMAIL=contact@example.ro
NEXT_PUBLIC_PHONE_DISPLAY=
NEXT_PUBLIC_PHONE_HREF=
NEXT_PUBLIC_WHATSAPP_NUMBER=
NEXT_PUBLIC_BUSINESS_ADDRESS=
NEXT_PUBLIC_BUSINESS_SCHEDULE=L-V · 08:00-18:00

# Public social profiles used by schema.org and future social links.
NEXT_PUBLIC_FACEBOOK_URL=
NEXT_PUBLIC_INSTAGRAM_URL=
NEXT_PUBLIC_LINKEDIN_URL=

# Legal entity data displayed in legal pages and the footer.
# TODO(client): mandatory before commercial launch.
NEXT_PUBLIC_LEGAL_ENTITY_NAME=
NEXT_PUBLIC_REGISTRATION_NUMBER=
NEXT_PUBLIC_TAX_ID=
NEXT_PUBLIC_REGISTERED_OFFICE=

# Commercial input for the consultation estimator.
# TODO(client): set the approved base price in RON. Keep 0 to hide monetary ranges.
NEXT_PUBLIC_ESTIMATOR_BASE_PRICE_RON=0
