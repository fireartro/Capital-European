# HTTPS URL for the CRM, automation, or email service that receives form submissions.
# Do not use NEXT_PUBLIC_ for secrets.
CONTACT_WEBHOOK_URL=https://example.com/secure-contact-webhook

# Real public site URL used for canonical, sitemap, hreflang, OG, and JSON-LD.
# On Vercel without a custom domain, use the active project/deployment URL.
NEXT_PUBLIC_SITE_URL=https://example.vercel.app

# Optional: enable Google Analytics 4 only after you have the real ID.
NEXT_PUBLIC_GA_ID=
