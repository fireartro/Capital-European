# Copy this file to .env.local for local development or configure the same
# variables in Vercel. Never commit real secrets.

# Canonical production URL. No trailing slash.
NEXT_PUBLIC_SITE_URL=https://capitaleuropean.ro

# Optional server-only HTTPS endpoint that receives validated contact requests.
# If this is empty, the contact API can send directly through Resend.
CONTACT_WEBHOOK_URL=

# Direct email delivery through Resend. Keep RESEND_API_KEY secret.
# Create the key in Resend and verify the sending domain before production use.
RESEND_API_KEY=
CONTACT_FROM_EMAIL=Capital European <contact@capitaleuropean.ro>
CONTACT_TO_EMAIL=capitaleuropean.ro@gmail.com

# Resend Inbound: signed webhook forwarding contact@ messages to Gmail.
RESEND_WEBHOOK_SECRET=
INBOUND_FORWARD_TO=capitaleuropean.ro@gmail.com
INBOUND_FORWARD_FROM=Mesaj primit <contact@capitaleuropean.ro>
INBOUND_ALLOWED_RECIPIENTS=contact@capitaleuropean.ro

# Tracking IDs are public identifiers, but scripts load only after consent.
# GA4 format: G-XXXXXXXXXX
NEXT_PUBLIC_GA_ID=G-JJDLTV4VX9
# Public Google Maps/Business Profile URL used for the reviews CTA.
NEXT_PUBLIC_GOOGLE_BUSINESS_URL=https://www.google.com/maps?cid=14253260384950460462
# Server-only Google Places API credentials. Enable "Places API (New)" in Google Cloud,
# restrict the key to that API, and never expose it with a NEXT_PUBLIC_ prefix.
GOOGLE_PLACES_API_KEY=
GOOGLE_PLACE_ID=
# GTM format: GTM-XXXXXXX
NEXT_PUBLIC_GTM_ID=
# Microsoft Clarity project ID
NEXT_PUBLIC_CLARITY_PROJECT_ID=

# Public contact details.
NEXT_PUBLIC_CONTACT_EMAIL=contact@capitaleuropean.ro
NEXT_PUBLIC_PHONE_DISPLAY=+40 753 527 110
NEXT_PUBLIC_PHONE_HREF=+40753527110
NEXT_PUBLIC_WHATSAPP_NUMBER=+40753527110
NEXT_PUBLIC_BUSINESS_ADDRESS=Satu Mare, Piața Soarelui, Bl. UU6, et. 3, ap. 9, 440221
NEXT_PUBLIC_WORKING_OFFICE=Seini, Piața Unirii nr. 2
NEXT_PUBLIC_SECONDARY_OFFICE=Cluj-Napoca, Strada Oltului nr. 1
NEXT_PUBLIC_BUSINESS_SCHEDULE=L-V · 10:00-18:00

# Public social profiles used by schema.org and future social links.
NEXT_PUBLIC_FACEBOOK_URL=
NEXT_PUBLIC_INSTAGRAM_URL=
NEXT_PUBLIC_LINKEDIN_URL=

# Legal entity data displayed in legal pages and the footer.
NEXT_PUBLIC_LEGAL_ENTITY_NAME=1A BEST EVENTS SRL
NEXT_PUBLIC_REGISTRATION_NUMBER=J2017000108306
NEXT_PUBLIC_TAX_ID=RO37037033
NEXT_PUBLIC_REGISTERED_OFFICE=Satu Mare, Piața Soarelui, Bl. UU6, et. 3, ap. 9, 440221

# Content administration. Keep every value server-only.
ADMIN_USERNAME=
ADMIN_PASSWORD=
ADMIN_SESSION_SECRET=
# Privileged sessions expire after 60 minutes and after 15 minutes without activity.
ADMIN_SESSION_DURATION_MINUTES=60
ADMIN_IDLE_TIMEOUT_MINUTES=15

# PostgreSQL stores funding cards and announcements. Neon/Vercel injects one of these URLs.
DATABASE_URL=
# POSTGRES_URL may be used instead of DATABASE_URL by some Vercel integrations.
POSTGRES_URL=

# Vercel Blob stores uploaded images. New Vercel projects use OIDC + BLOB_STORE_ID.
BLOB_STORE_ID=
# Local or legacy setups may use a read-write token instead.
BLOB_READ_WRITE_TOKEN=
